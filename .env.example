# Application
APP_ENV=development
APP_NAME=quant-intel-brief
APP_TIMEZONE=America/New_York
DATABASE_URL=sqlite:///data/app.db
LOG_LEVEL=INFO

# Dashboard
WEB_HOST=127.0.0.1
WEB_PORT=8000
DASHBOARD_BASE_URL=http://127.0.0.1:8000
DASHBOARD_TITLE=Quant Intel Brief

# OpenAI-compatible LLM
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# DeepSeek-compatible legacy aliases
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# News and market source APIs
RSS_FEED_URLS=
NEWSAPI_KEY=
GDELT_API_KEY=
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=
FRED_API_KEY=
FRED_SERIES_ID=FEDFUNDS
SEC_USER_AGENT=
SEC_CIK=0000320193
ARXIV_SEARCH_QUERY=cat:q-fin*

# Developer and social source APIs
GITHUB_TOKEN=
GITHUB_QUERY=quant finance language:Python
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_ACCESS_TOKEN=
REDDIT_USER_AGENT=
YOUTUBE_API_KEY=
X_BEARER_TOKEN=
STACKEXCHANGE_KEY=
QUANTCONNECT_USER_ID=
QUANTCONNECT_TOKEN=
QUANTCONNECT_ORGANIZATION_ID=

# Email
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
RESEND_API_KEY=
RESEND_FROM=
REPORT_RECIPIENTS=

# Runtime controls
COLLECTOR_TIMEOUT_SECONDS=30
MAX_ITEMS_PER_SOURCE=200
HTTP_RETRY_ATTEMPTS=2
HTTP_RETRY_BACKOFF_SECONDS=1
RETENTION_DAYS=30
ENABLE_SCHEDULER=false
DAILY_RUN_TIME=07:00
STORE_FULL_TEXT=false
ENABLE_PREMIUM_BROWSER=false
